# Shared backend (desktop, mobile, web)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_public_anon_key

# Runtime mode
# dashboard -> web control panel for Vercel
# runtime   -> full Jarvis client runtime
VITE_APP_MODE=runtime

# Voice stack
VOICE_PROVIDER=local_whisper
VITE_WHISPER_MODEL=base
VITE_WHISPER_DEVICE=cpu
# Use gpu when a local GPU runtime is available
# VITE_WHISPER_DEVICE=gpu

# LLM provider routing
VITE_LLM_PROVIDER=deepseek
OPENAI_API_KEY=your_openai_key
CLAUDE_API_KEY=your_claude_key
DEEPSEEK_API_KEY=your_deepseek_key
CUSTOM_API_URL=https://api.example.com
CUSTOM_API_KEY=your_custom_api_key

# Agent runtime (embedded only)
AGENT_RUNTIME=embedded
AGENT_ENGINE=langgraph
