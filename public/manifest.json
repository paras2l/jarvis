    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable any"
    }
  ],
  "screenshots": [],
  "shortcuts": [
    {
      "name": "New Task",
      "short_name": "Task",
      "description": "Give Pixi a new task",
      "url": "/?action=new-task",
      "icons": [{ "src": "/favicon.ico", "sizes": "48x48" }]
    },
    {
      "name": "Voice Mode",
      "short_name": "Voice",
      "description": "Talk to Pixi",
      "url": "/?action=voice",
      "icons": [{ "src": "/favicon.ico", "sizes": "48x48" }]
    }
  ],
  "share_target": {
    "action": "/?action=share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
